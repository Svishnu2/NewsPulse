# Copy to .env for local runs. Never commit .env.
GEMINI_API_KEY=your-google-ai-studio-key
# Set to whichever Flash model your free AI Studio key supports.
GEMINI_MODEL=gemini-flash-latest
# Optional — Telegram morning summary + intraday monitor alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set to 1 to bypass the holiday / late-start guards when testing.
FORCE_RUN=
